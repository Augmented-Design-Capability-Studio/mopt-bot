venv/
.DS_Store

# Stray DB stubs from running the server with the wrong CWD. The real
# study DB lives at backend/data/mopt_study.db (gitignored by
# backend/.gitignore). The server os.chdir's to backend/ before opening
# the sqlite URL, so anything under /data/ at the repo root is an
# accident and should not be tracked.
/data/

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
*.egg

# Local env files
.env
.env.*

# Local test secrets (Gemini API key, etc. — see backend/.secrets/README.md)
backend/.secrets/*
!backend/.secrets/README.md
