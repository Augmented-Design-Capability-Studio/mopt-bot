# TEMPLATE ONLY — copy to `.env` (same folder or repo root) and edit.
# The app loads `.env`, not this file. Never commit real `.env` values.

# Server (used by run_server.py unless you pass --host / --port)
MOPT_HOST=0.0.0.0
MOPT_PORT=8000
MOPT_PUBLIC_URL=http://localhost:8000

# SQLite path (absolute or relative to cwd when starting uvicorn)
MOPT_DATABASE_URL=sqlite:///./data/mopt_study.db

# CORS: comma-separated origins (Vercel + local Vite)
MOPT_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173

# Auth: Bearer tokens for participant vs researcher apps
MOPT_CLIENT_SECRET=adcs2026
MOPT_RESEARCHER_SECRET=needfinding2026

# Optional: encrypt stored API keys (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# MOPT_FERNET_KEY=

# Solver
MOPT_SOLVE_TIMEOUT_SEC=120

# Default Gemini model id (participant/researcher can override in UI)
# Use a model id your API key can call (ListModels in Google AI Studio). Preview ids change over time.
MOPT_DEFAULT_GEMINI_MODEL=gemini-3-flash-preview
